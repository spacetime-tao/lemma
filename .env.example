# Chain
SUBTENSOR_NETWORK=finney
SUBTENSOR_CHAIN_ENDPOINT=wss://entrypoint-finney.opentensor.ai:443
NETUID=0

# Problems: generated (seed → template; default) or frozen JSON catalog
# LEMMA_PROBLEM_SOURCE=generated
# Theorem seed: subnet_epoch (default, Tempo stride — same chain head => same seed) or quantize (N-block windows)
# Fixed N-block rounds (default 100 blocks ≈ 20 min at LEMMA_BLOCK_TIME_SEC_ESTIMATE=12).
LEMMA_PROBLEM_SEED_MODE=quantize
LEMMA_PROBLEM_SEED_QUANTIZE_BLOCKS=100
# Alternatively: follow subnet Tempo from chain RPC.
# LEMMA_PROBLEM_SEED_MODE=subnet_epoch
# LEMMA_MINIF2F_CATALOG_PATH=
# Pin template registry (optional; run `lemma meta` after upgrades)
# LEMMA_GENERATED_REGISTRY_SHA256_EXPECTED=

# Wallets (names under ~/.bittensor/wallets)
BT_WALLET_COLD=default
BT_WALLET_HOT=default
# Optional: validator signing keys if they differ from miner (defaults = BT_WALLET_* above)
# If unset, the validator uses BT_WALLET_* (same as miner). Set both when validator keys differ:
# BT_VALIDATOR_WALLET_COLD=
# BT_VALIDATOR_WALLET_HOT=

# Miner axon (validators must reach IP:AXON_PORT)
AXON_PORT=8091
# If unset, Lemma tries HTTPS public-IP discovery (disable with AXON_DISCOVER_EXTERNAL_IP=false).
# For local-only testing set explicitly, e.g. AXON_EXTERNAL_IP=127.0.0.1
# AXON_EXTERNAL_IP=
# AXON_DISCOVER_EXTERNAL_IP=true

# Validator
LEAN_SANDBOX_IMAGE=lemma/lean-sandbox:latest
# Docker/host lake build budget per submission (default 300 = 5 minutes; increase if Mathlib builds time out).
LEAN_VERIFY_TIMEOUT_S=300
LEAN_SANDBOX_CPU=2.0
LEAN_SANDBOX_MEM_MB=8192
# Docker network for Lean sandbox: `none` is safest on validators (default). On your laptop,
# `lemma try-prover --verify` runs `lake` in Docker — first-time Mathlib fetch needs GitHub:
#   LEAN_SANDBOX_NETWORK=bridge
# Or keep `none` only if your sandbox image already contains Mathlib (prebuilt / warm cache).
# LEAN_SANDBOX_NETWORK=none
# Forward HTTP wait for one miner answer = blocks until next seed edge × block time (then clamped).
# LEMMA_BLOCK_TIME_SEC_ESTIMATE=12
# LEMMA_FORWARD_WAIT_MIN_S=60
# LEMMA_FORWARD_WAIT_MAX_S=86400
# LEMMA_MINER_REJECT_PAST_DEADLINE_BLOCK=1
# LLM HTTP read timeout for prover + judge (Chutes long generations; raise if connections drop mid-stream).
# LEMMA_LLM_HTTP_TIMEOUT_S=900
# Subnet policy only: if the operator publishes split multipliers, set these consistently on every validator.
# LEMMA_TIMEOUT_SCALE_BY_SPLIT=0
# LEMMA_TIMEOUT_SPLIT_EASY_MULT=1
# LEMMA_TIMEOUT_SPLIT_MEDIUM_MULT=1.5
# LEMMA_TIMEOUT_SPLIT_HARD_MULT=2
# Seconds between validator rounds (default 300). Ignored if LEMMA_VALIDATOR_ALIGN_ROUNDS_TO_EPOCH=1.
# LEMMA_VALIDATOR_ROUND_INTERVAL_S=300
# Set to 1 to wait for chain epoch boundaries before each round (legacy cadence).
# LEMMA_VALIDATOR_ALIGN_ROUNDS_TO_EPOCH=0
EMPTY_EPOCH_WEIGHTS_POLICY=skip
SET_WEIGHTS_MAX_RETRIES=3
SET_WEIGHTS_RETRY_DELAY_S=2
# VALIDATOR_ABORT_IF_NOT_REGISTERED=0
# Append PRM training rows (JSONL) per epoch for judged miners:
# LEMMA_TRAINING_EXPORT_JSONL=/var/lib/lemma/training.jsonl
# Optional post-verify binary (see docs/COMPARATOR.md):
# LEMMA_COMPARATOR_ENABLED=0
# LEMMA_COMPARATOR_CMD=

# Miner — prover LLM (writes Submission.lean; distinct from validator judge)
# PROVER_PROVIDER=anthropic
# Miner-only model id (OpenAI-compatible = HF-style id on Chutes/vLLM; falls back to OPENAI_MODEL if unset).
# Anthropic provers fall back to ANTHROPIC_MODEL if unset. Judges never read PROVER_MODEL.
# PROVER_MODEL=
# Prover LLM sampling temperature (OpenAI + Anthropic prover). Default 0.3; raise slightly for more variation.
# LEMMA_PROVER_TEMPERATURE=0.3
# Optional text appended to the built-in prover system prompt on every API call (tone, lay audience, etc.).
# Gemini / ChatGPT "saved system instructions" in a web UI do NOT apply to Lemma — put those rules here instead.
# CLI (recommended): lemma configure prover-system-append   (also --file path.txt / --clear)
# LEMMA_PROVER_SYSTEM_APPEND=
# Max completion tokens per prover call (JSON reasoning + Submission.lean). Default 32768; raise for huge proofs.
# LEMMA_PROVER_MAX_TOKENS=32768
# Transient prover errors (429, timeouts): tries per forward (exponential backoff). Default 4; raise if gateway is often saturated.
# LEMMA_PROVER_LLM_RETRY_ATTEMPTS=4
# Optional: enforce minimum informal reasoning (0 = off). Rejects JSON that is too terse so miners retry.
# LEMMA_PROVER_MIN_REASONING_STEPS=4
# LEMMA_PROVER_MIN_REASONING_TOTAL_CHARS=1200
# Optional: enforce minimum length of full Submission.lean (0 = off). Stricter formal verbosity than prompt alone.
# LEMMA_PROVER_MIN_PROOF_SCRIPT_CHARS=
# Or interactively: lemma configure prover-retries   ; one-off try-prover: lemma try-prover --retry-attempts 8
# Cap forwards per UTC day to limit API spend (0=unlimited). Persists under ~/.lemma/
# MINER_MAX_FORWARDS_PER_DAY=0

# Miner safety (optional prod)
# MINER_MIN_VALIDATOR_STAKE=0
# MINER_PRIORITY_BY_STAKE=0
# MINER_METAGRAPH_REFRESH_S=300
# MINER_MAX_CONCURRENT_FORWARDS=8
# One INFO line per forward + session averages (see also LEMMA_MINER_LOG_FORWARDS).
# LEMMA_MINER_FORWARD_SUMMARY=1
# Log reasoning + proof excerpts per forward (INFO); raw model JSON at DEBUG if log level allows.
# LEMMA_MINER_LOG_FORWARDS=0
# Optional: lake-build Submission.lean locally after each forward (Docker + LEAN_SANDBOX_* like validators).
# LEMMA_MINER_LOCAL_VERIFY=0
# MINER_REQUIRE_VALIDATOR_PERMIT=0
# SYNAPSE_MAX_STATEMENT_CHARS=500000

# Judge — JUDGE_PROVIDER=openai means "use the OpenAI-*compatible* HTTP client", NOT "use OpenAI's models".
# Defaults target Chutes (https://llm.chutes.ai/v1). For self-hosted vLLM use e.g. OPENAI_BASE_URL=http://127.0.0.1:8000/v1 and OPENAI_MODEL=<loaded HF id>.
# Pin ONE stack per subnet; run `lemma meta` and optionally set JUDGE_PROFILE_SHA256_EXPECTED on validators.
JUDGE_PROVIDER=openai
JUDGE_TEMPERATURE=0.2
JUDGE_MAX_TOKENS=256
# Optional: validator exits unless env matches `lemma meta` output (anti-accidental drift)
# JUDGE_PROFILE_SHA256_EXPECTED=
# If 1, refuse to start validator until JUDGE_PROFILE_SHA256_EXPECTED (+ registry pin for generated) are set.
# LEMMA_VALIDATOR_ENFORCE_PUBLISHED_META=0
# Only for dev: allow a judge model other than OPENAI_MODEL=deepseek-ai/DeepSeek-V3.2-TEE
# LEMMA_ALLOW_NONCANONICAL_JUDGE_MODEL=0
# Set to 1 to use standard pydantic order: process env overrides .env (CI / Docker-only env)
# LEMMA_PREFER_PROCESS_ENV=0
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
OPENAI_API_KEY=
# Required judge model for validators (OpenAI-compatible id). Experiments: LEMMA_ALLOW_NONCANONICAL_JUDGE_MODEL=1
OPENAI_MODEL=deepseek-ai/DeepSeek-V3.2-TEE
OPENAI_BASE_URL=https://llm.chutes.ai/v1

# Optional
WANDB_API_KEY=
LOG_LEVEL=INFO
