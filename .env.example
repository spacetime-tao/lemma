# CLI (optional): after `uv run lemma` interactive START HERE, Lemma execs a subshell with `.venv` active.
# Set to 1 to skip (stay in the outer shell only).
# LEMMA_NO_INTERACTIVE_VENV_SHELL=1
# Rare: force nested PTY relay instead of default exec + `/dev/tty` (IDE terminals prefer the default).
# LEMMA_INTERACTIVE_VENV_USE_PTY=1

# Chain — Lemma: Bittensor testnet + NETUID 467 (wizard sets this path only).
SUBTENSOR_NETWORK=test
SUBTENSOR_CHAIN_ENDPOINT=wss://test.finney.opentensor.ai:443
NETUID=467

# Future Finney (mainnet) — hand-edit when Lemma has a mainnet netuid (not sn0 / root).
# SUBTENSOR_NETWORK=finney
# SUBTENSOR_CHAIN_ENDPOINT=wss://entrypoint-finney.opentensor.ai:443
# NETUID=

# Problems: generated (seed → template; default) or frozen JSON catalog
# LEMMA_PROBLEM_SOURCE=generated
# Opt-in only — frozen = public miniF2F-style catalog (not default for subnet-like traffic).
# LEMMA_DEV_ALLOW_FROZEN_PROBLEM_SOURCE=0
# Theorem seed: subnet_epoch (default, Tempo stride — same chain head => same seed) or quantize (N-block windows)
# Fixed N-block rounds (default 100 blocks ≈ 20 min at LEMMA_BLOCK_TIME_SEC_ESTIMATE=12).
LEMMA_PROBLEM_SEED_MODE=quantize
LEMMA_PROBLEM_SEED_QUANTIZE_BLOCKS=100
# Optional: subtract blocks from RPC head before seed + axon wait (align validators across endpoints).
# LEMMA_PROBLEM_SEED_CHAIN_HEAD_SLACK_BLOCKS=0
# Alternatively: follow subnet Tempo from chain RPC.
# LEMMA_PROBLEM_SEED_MODE=subnet_epoch
# LEMMA_MINIF2F_CATALOG_PATH=
# Pin template registry (optional; run `lemma meta` after upgrades)
# LEMMA_GENERATED_REGISTRY_SHA256_EXPECTED=
# Rare rollback: use legacy random.Random(seed) without SHA256 mix (see docs/catalog-sources.md).
# LEMMA_GENERATED_LEGACY_PLAIN_RNG=0

# Wallets (names under ~/.bittensor/wallets)
BT_WALLET_COLD=default
BT_WALLET_HOT=default
# Optional: validator signing keys if they differ from miner (defaults = BT_WALLET_* above)
# If unset, the validator uses BT_WALLET_* (same as miner). Set both when validator keys differ:
# BT_VALIDATOR_WALLET_COLD=
# BT_VALIDATOR_WALLET_HOT=

# Miner axon (validators must reach IP:AXON_PORT)
AXON_PORT=8091
# If unset, Lemma tries HTTPS public-IP discovery (disable with AXON_DISCOVER_EXTERNAL_IP=false).
# For local-only testing set explicitly, e.g. AXON_EXTERNAL_IP=127.0.0.1
# AXON_EXTERNAL_IP=
# AXON_DISCOVER_EXTERNAL_IP=true

# Validator
LEAN_SANDBOX_IMAGE=lemma/lean-sandbox:latest
# Docker/host lake build budget per submission (default 300 = 5 minutes; increase if Mathlib builds time out).
LEAN_VERIFY_TIMEOUT_S=300
LEAN_SANDBOX_CPU=2.0
LEAN_SANDBOX_MEM_MB=8192
# Fast Docker verify (optional): long-lived container + `docker exec` — see docs/validator.md.
# Must appear in .env (LemmaSettings); shell-only export is ignored unless LEMMA_PREFER_PROCESS_ENV=1.
# LEMMA_LEAN_DOCKER_WORKER=lemma-lean-worker
# LEMMA_LEAN_DOCKER_WORKER_MOUNT=/lemma-workspace
# LEMMA_LEAN_DOCKER_WORKER_HOST_ROOT=/var/lib/lemma-lean-cache   # if unset, uses LEMMA_LEAN_VERIFY_WORKSPACE_CACHE_DIR
#
# Optional: delegate Lean verify to another host (HTTP POST /verify). Worker runs `lemma lean-worker` with the same
# Lean `.env` / Docker/cache as production. Margin is added to LEMMA_LEAN_VERIFY_TIMEOUT_S for the HTTP read timeout.
# LEMMA_LEAN_VERIFY_REMOTE_URL=http://10.0.0.5:8787
# LEMMA_LEAN_VERIFY_REMOTE_BEARER=change-me
# LEMMA_LEAN_VERIFY_REMOTE_TIMEOUT_MARGIN_S=30
# Lean thread pool (Lake / elaboration); default = logical cores (cap 64). Lower if cgroup CPU is tight.
# LEMMA_LEAN_NUM_THREADS=16
# Log wall-clock phases for verify (INFO): docker exec vs one-shot, LEAN_NUM_THREADS
# LEMMA_LEAN_VERIFY_TIMING=1
# Skip redundant `lake exe cache get` when `.lake/packages/mathlib` exists (default on).
# LEMMA_LEAN_ALWAYS_CACHE_GET=1
# LEMMA_LEAN_SKIP_CACHE_GET_WHEN_WARM=0

# Docker vs host Lean verify — default: Docker (same as subnet validators).
# LEMMA_USE_DOCKER=true
# `lemma validator` requires Docker — do not set false for validator machines.
# Optional miner/local-only host lake (toolchain must match LEAN_SANDBOX_IMAGE):
# LEMMA_USE_DOCKER=false

# Opt-in to host `lake` for `lemma verify --host-lean` and `lemma-cli try-prover --host-lean` / LEMMA_TRY_PROVER_HOST_VERIFY
# (local debugging; production should use Docker):
# LEMMA_ALLOW_HOST_LEAN=0

# Docker network for Lean sandbox: `none` is safest on validators (default). For cold Mathlib fetches, `bridge` helps.
#   LEAN_SANDBOX_NETWORK=bridge
# LEAN_SANDBOX_NETWORK=none
#
# try-prover — warm cache (default `XDG_CACHE_HOME/lemma-lean-workspace` when unset):
#   LEMMA_LEAN_VERIFY_WORKSPACE_CACHE_DIR=...
#   LEMMA_TRY_PROVER_NO_WORKSPACE_CACHE=1
#   LEMMA_TRY_PROVER_DOCKER_VERIFY=1              force Docker even if you toggled host elsewhere
#   LEMMA_TRY_PROVER_HOST_VERIFY=1                host lake (requires LEMMA_ALLOW_HOST_LEAN=1)
#   LEMMA_HOST_LAKE_CACHE_BEFORE_DOCKER=1         host `lake exe cache get` before Docker (cold `.lake`)
#   LEMMA_LEAN_VERIFY_FULL_BUILD=1               full `lake build` (default: Submission only)
# Forward HTTP wait for one miner answer = blocks until next seed edge × block time (then clamped).
# LEMMA_BLOCK_TIME_SEC_ESTIMATE=12
# LEMMA_FORWARD_WAIT_MIN_S=60
# LEMMA_FORWARD_WAIT_MAX_S=86400
# LEMMA_MINER_REJECT_PAST_DEADLINE_BLOCK=1
# LLM HTTP read timeout for prover + judge (Chutes long generations; raise if connections drop mid-stream).
# LEMMA_LLM_HTTP_TIMEOUT_S=900
# Subnet policy only: if the operator publishes split multipliers, set these consistently on every validator.
# LEMMA_TIMEOUT_SCALE_BY_SPLIT=0
# LEMMA_TIMEOUT_SPLIT_EASY_MULT=1
# LEMMA_TIMEOUT_SPLIT_MEDIUM_MULT=1.5
# LEMMA_TIMEOUT_SPLIT_HARD_MULT=2
EMPTY_EPOCH_WEIGHTS_POLICY=skip
SET_WEIGHTS_MAX_RETRIES=3
SET_WEIGHTS_RETRY_DELAY_S=2
# VALIDATOR_ABORT_IF_NOT_REGISTERED=0
# Append PRM training rows (JSONL) per epoch for judged miners:
# LEMMA_TRAINING_EXPORT_JSONL=/var/lib/lemma/training.jsonl
# LEMMA_TRAINING_EXPORT_PROFILE=full
#   reasoning_only — omit proof_script, rubric, pareto_weight (see docs/training_export.md)
# Optional post-verify binary (see docs/comparator.md):
# LEMMA_COMPARATOR_ENABLED=0
# LEMMA_COMPARATOR_CMD=

# Miner — prover LLM (writes Submission.lean; distinct from validator judge)
# PROVER_PROVIDER=anthropic
# Miner-only model id (OpenAI-compatible = HF-style id on Chutes/vLLM; falls back to OPENAI_MODEL if unset).
# Anthropic provers fall back to ANTHROPIC_MODEL if unset. Judges never read PROVER_MODEL.
# PROVER_MODEL=
# Prover LLM sampling temperature (OpenAI + Anthropic prover). Default 0.3; raise slightly for more variation.
# LEMMA_PROVER_TEMPERATURE=0.3
# Max completion tokens per prover call (JSON reasoning + Submission.lean). Default 32768; raise for huge proofs.
# LEMMA_PROVER_MAX_TOKENS=32768
# Transient prover errors (429, timeouts): tries per forward (exponential backoff). Default 4; raise if gateway is often saturated.
# LEMMA_PROVER_LLM_RETRY_ATTEMPTS=4
# Optional: enforce minimum informal reasoning (0 = off). Rejects JSON that is too terse so miners retry.
# LEMMA_PROVER_MIN_REASONING_STEPS=4
# LEMMA_PROVER_MIN_REASONING_TOTAL_CHARS=1200
# Optional: enforce minimum length of full Submission.lean (0 = off). Stricter formal verbosity than prompt alone.
# LEMMA_PROVER_MIN_PROOF_SCRIPT_CHARS=
# Or interactively: lemma-cli configure prover-retries   ; one-off try-prover: lemma-cli try-prover --retry-attempts 8
# Cap forwards per UTC day to limit API spend (0=unlimited). Persists under ~/.lemma/
# MINER_MAX_FORWARDS_PER_DAY=0

# Miner safety (optional prod)
# MINER_MIN_VALIDATOR_STAKE=0
# MINER_PRIORITY_BY_STAKE=0
# MINER_METAGRAPH_REFRESH_S=300
# MINER_MAX_CONCURRENT_FORWARDS=8
# One INFO line per forward + session averages (see also LEMMA_MINER_LOG_FORWARDS).
# LEMMA_MINER_FORWARD_SUMMARY=1
# Per forward: RECEIVE (deadline vs chain head) → SOLVED → OUTCOME (+ miner answered). See docs/miner.md.
# LEMMA_MINER_FORWARD_TIMELINE=0
# Log reasoning + proof excerpts per forward (INFO); raw model JSON at DEBUG if log level allows.
# LEMMA_MINER_LOG_FORWARDS=0
# Optional: lake-build Submission.lean locally after each forward (Docker + LEAN_SANDBOX_* like validators).
# LEMMA_MINER_LOCAL_VERIFY=0
# MINER_REQUIRE_VALIDATOR_PERMIT=0
# SYNAPSE_MAX_STATEMENT_CHARS=500000

# Judge — JUDGE_PROVIDER=chutes is the subnet default (Chutes via OpenAI-compatible HTTP). Legacy alias: openai.
# Pin ONE stack per subnet; validators must set JUDGE_PROFILE_SHA256_EXPECTED (see `lemma-cli configure subnet-pins`).
JUDGE_PROVIDER=chutes
JUDGE_TEMPERATURE=0.2
JUDGE_MAX_TOKENS=256
# Judge HTTP: retries on 429/5xx (per score); optional tighter read timeout than LEMMA_LLM_HTTP_TIMEOUT_S
# LEMMA_JUDGE_LLM_RETRY_ATTEMPTS=4
# LEMMA_JUDGE_HTTP_TIMEOUT_S=
# Required for validators: must match live `lemma meta` (anti drift). Run `lemma-cli configure subnet-pins`.
# JUDGE_PROFILE_SHA256_EXPECTED=
# When LEMMA_PROBLEM_SOURCE=generated, validators also require LEMMA_GENERATED_REGISTRY_SHA256_EXPECTED=
# Ignored by `lemma validator` (kept for compatibility). Do not use to bypass Chutes judge policy.
# LEMMA_ALLOW_NONCANONICAL_JUDGE_MODEL=0
# Dry-run epochs (`lemma validator dry-run`, or `lemma validator start --dry-run`) use FakeJudge for the rubric
# step by default. Set to 1 to call your real judge HTTP while still skipping set_weights (can be costly).
# LEMMA_DRY_RUN_REAL_JUDGE=0
# Set to 1 to use standard pydantic order: process env overrides .env (CI / Docker-only env)
# LEMMA_PREFER_PROCESS_ENV=0
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
# Judge Chutes key (recommended). If unset, judge falls back to OPENAI_API_KEY (legacy shared name).
# JUDGE_OPENAI_API_KEY=
# Legacy: one key for judge when JUDGE_OPENAI_API_KEY is unset. Prefer JUDGE_OPENAI_API_KEY + PROVER_OPENAI_API_KEY
# so Gemini (prover) and Chutes (judge) never overwrite each other.
OPENAI_API_KEY=
# Judge for validators: Chutes DeepSeek only (`lemma validator` enforces model + base URL).
OPENAI_MODEL=deepseek-ai/DeepSeek-V3.2-TEE
OPENAI_BASE_URL=https://llm.chutes.ai/v1
# Miner prover (PROVER_PROVIDER=openai): override gateway without changing the judge stack above.
# If unset, prover uses OPENAI_BASE_URL; if PROVER_OPENAI_API_KEY is unset, prover uses OPENAI_API_KEY.
# PROVER_OPENAI_BASE_URL=
# PROVER_OPENAI_API_KEY=

# Incentive / scoring (validators) — see docs/incentive_migration.md
# LEMMA_SCORE_PROOF_WEIGHT=0.35
# LEMMA_SCORING_DEDUP_IDENTICAL=1
# LEMMA_SCORING_COLDKEY_DEDUP=1
# LEMMA_REPUTATION_EMA_ALPHA=0.08
# LEMMA_REPUTATION_VERIFY_CREDIBILITY_ALPHA=0.08
# LEMMA_REPUTATION_CREDIBILITY_EXPONENT=1.0
# LEMMA_REPUTATION_STATE_PATH=
# LEMMA_PROOF_INTRINSIC_STRIP_COMMENTS=1
# LEMMA_EPOCH_PROBLEM_COUNT=1
# LEMMA_PARETO_TOKEN_MODEL=gpt-4
# Miner verify attest (validators verify Sr25519 signatures; miners must use LEMMA_MINER_LOCAL_VERIFY=1 + PASS):
# LEMMA_MINER_VERIFY_ATTEST_ENABLED=0
# After attest is stable, lower toward 0–1 to reduce Docker Lean load (deterministic spot checks). Default 1.0 = always full verify.
# LEMMA_MINER_VERIFY_ATTEST_SPOT_VERIFY_FRACTION=1.0
# Two-phase commit then reveal per epoch sub-round (validator runs commit forward then reveal forward — ~2× axon latency):
# LEMMA_COMMIT_REVEAL_ENABLED=0
# Judge profile peer attest (optional — HTTP GET each URL must return your judge_profile_sha256):
# LEMMA_JUDGE_PROFILE_ATTEST_ENABLED=0
# LEMMA_JUDGE_PROFILE_ATTEST_PEER_URLS=http://peer1:8799/lemma/judge_profile_sha256,http://peer2:8799/lemma/judge_profile_sha256
# LEMMA_JUDGE_PROFILE_ATTEST_SKIP=0
# LEMMA_JUDGE_PROFILE_ATTEST_HTTP_TIMEOUT_S=15

# Validator epoch throughput (many miners / strict judge RPM — tune per machine + provider)
# See docs/validator_lean_load.md
# LEMMA_LEAN_VERIFY_MAX_CONCURRENT=4
# LEMMA_JUDGE_MAX_CONCURRENT=8
# Optional: reuse a warm `.lake` per theorem template (fast after first passing verify for that template). Use fast SSD; prune old subdirs if disk fills.
# LEMMA_LEAN_VERIFY_WORKSPACE_CACHE_DIR=/var/lib/lemma-lean-cache
# Rare: isolate cache slots per proof body (more disk). Default: template-only key (shared incremental rebuild).
# LEMMA_LEAN_WORKSPACE_CACHE_INCLUDE_SUBMISSION_HASH=0

# Optional
WANDB_API_KEY=
LOG_LEVEL=INFO
