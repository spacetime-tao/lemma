# Lemma minimal environment.

# Chain. Set these to the Lemma subnet before live use.
SUBTENSOR_NETWORK=test
SUBTENSOR_CHAIN_ENDPOINT=wss://test.finney.opentensor.ai:443
NETUID=467

# Problem supply: known-theorem targets only.
LEMMA_PROBLEM_SOURCE=known_theorems
# LEMMA_KNOWN_THEOREMS_MANIFEST_PATH=
# LEMMA_LEDGER_PATH=/var/lib/lemma/solved-ledger.jsonl
# LEMMA_MINER_SUBMISSIONS_PATH=/var/lib/lemma/submissions.json

# Wallets under ~/.bittensor/wallets.
BT_WALLET_COLD=default
BT_WALLET_HOT=default
# Optional validator signing keys if they differ from the miner keys.
# BT_VALIDATOR_WALLET_COLD=
# BT_VALIDATOR_WALLET_HOT=

# Miner axon.
AXON_PORT=8091
# AXON_EXTERNAL_IP=

# Lean verification.
LEAN_SANDBOX_IMAGE=lemma/lean-sandbox:latest
LEAN_SANDBOX_CPU=2.0
LEAN_SANDBOX_MEM_MB=8192
LEAN_SANDBOX_NETWORK=none
LEMMA_USE_DOCKER=true
# Host Lean is local-only and opt-in for `lemma verify --host-lean`.
LEMMA_ALLOW_HOST_LEAN=0
LEAN_VERIFY_TIMEOUT_S=300
LEMMA_LEAN_VERIFY_MAX_CONCURRENT=4
# LEMMA_LEAN_VERIFY_WORKSPACE_CACHE_DIR=/var/lib/lemma-lean-cache
# LEMMA_LEAN_WORKSPACE_CACHE_MAX_DIRS=8
# LEMMA_LEAN_WORKSPACE_CACHE_MAX_BYTES=17179869184
# LEMMA_LEAN_NUM_THREADS=16
# LEMMA_LEAN_ALWAYS_CACHE_GET=1

# Validator polling and chain writes.
LEMMA_VALIDATOR_POLL_INTERVAL_S=300
LEMMA_VALIDATOR_POLL_TIMEOUT_S=30
LEMMA_VALIDATOR_ABORT_IF_NOT_REGISTERED=true
LEMMA_VALIDATOR_MIN_FREE_BYTES=1073741824
LEMMA_SET_WEIGHTS_MAX_RETRIES=3
LEMMA_SET_WEIGHTS_RETRY_DELAY_S=2

# Required validator pins. Copy from `lemma meta --raw`.
# LEMMA_KNOWN_THEOREMS_MANIFEST_SHA256_EXPECTED=
# LEMMA_VALIDATOR_PROFILE_SHA256_EXPECTED=

# Wire payload limits.
SYNAPSE_MAX_STATEMENT_CHARS=500000
SYNAPSE_MAX_PROOF_CHARS=500000

# Misc.
# Set to 1 when process env should override .env values.
# LEMMA_PREFER_PROCESS_ENV=0
LOG_LEVEL=INFO
